---
interface Props {
  title: string;
  description?: string;
}

const { title, description = '滨州索引 - 滨州地名志高端门户网站' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:image" content="https://keyi.de5.net/og-image.png" />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:site_name" content="滨州索引" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://keyi.de5.net/og-image.png" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "滨州索引",
      "description": description,
      "url": "https://keyi.de5.net/",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://keyi.de5.net/place?search={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    })} />
  </head>
  <body class="min-h-screen bg-gray-50">
    <slot />
  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
  }
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  }
</style>
