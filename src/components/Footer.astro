---
const contact = {
  address: '滨州市黄河十一路渤海二路豪德广场西一街70号',
  phone: '13326280320'
};
---

<footer class="bg-gray-800 text-white mt-16">
  <div class="max-w-7xl mx-auto px-4 py-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h3 class="text-lg font-bold mb-4">滨州索引</h3>
        <p class="text-gray-400 text-sm">
          滨州地名志高端门户网站<br/>
          收录滨州地名志、小区索引、装修教程等信息
        </p>
      </div>

      <div>
        <h3 class="text-lg font-bold mb-4">联系方式</h3>
        <ul class="text-gray-400 text-sm space-y-2">
          <li>📍 {contact.address}</li>
          <li>📞 {contact.phone}</li>
        </ul>
      </div>

      <div>
        <h3 class="text-lg font-bold mb-4">快速链接</h3>
        <ul class="text-gray-400 text-sm space-y-2">
          <li><a href="/place" class="hover:text-white">滨州地名志</a></li>
          <li><a href="/community" class="hover:text-white">小区索引</a></li>
          <li><a href="/blog" class="hover:text-white">文章博客</a></li>
          <li><a href="/tutorial" class="hover:text-white">装修教程</a></li>
          <li><a href="/product" class="hover:text-white">产品展示</a></li>
          <li><a href="/source" class="hover:text-white">数据来源</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-700 mt-8 pt-8 text-center text-gray-400 text-sm">
      <p>&copy; {new Date().getFullYear()} 滨州索引. All rights reserved.</p>
      <p class="mt-2 space-x-4">
        <a href="/about" class="text-gray-500 hover:text-gray-300">关于我们</a>
        <span class="text-gray-600">|</span>
        <a href="/privacy" class="text-gray-500 hover:text-gray-300">隐私政策</a>
        <span class="text-gray-600">|</span>
        <a href="/source" class="text-gray-500 hover:text-gray-300">数据来源声明</a>
      </p>
    </div>
  </div>
</footer>
