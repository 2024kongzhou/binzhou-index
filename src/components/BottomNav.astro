---
const tabs = [
  { name: '首页', href: '/', icon: 'home' },
  { name: '地名志', href: '/place', icon: 'place' },
  { name: '教程', href: '/tutorial', icon: 'tutorial' },
  { name: '产品', href: '/product', icon: 'product' },
  { name: '小区', href: '/community', icon: 'community' },
];
---

<nav class="bottom-nav" id="bottom-nav">
  {tabs.map(tab => (
    <a href={tab.href} class="bottom-tab" data-href={tab.href}>
      <div class="tab-icon">
        {tab.icon === 'home' && (
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
            <polyline points="9 22 9 12 15 12 15 22"></polyline>
          </svg>
        )}
        {tab.icon === 'place' && (
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"></path>
            <circle cx="12" cy="9" r="2.5"></circle>
          </svg>
        )}
        {tab.icon === 'tutorial' && (
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
          </svg>
        )}
        {tab.icon === 'product' && (
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
            <path d="M16 7V5a4 4 0 0 0-8 0v2"></path>
          </svg>
        )}
        {tab.icon === 'community' && (
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
            <polyline points="9 22 9 12 15 12 15 22"></polyline>
          </svg>
        )}
      </div>
      <span class="tab-label">{tab.name}</span>
    </a>
  ))}
</nav>

<style>
  .bottom-nav {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 900;
    display: flex;
    justify-content: space-around;
    align-items: center;
    padding: 0.5rem 0;
    padding-bottom: max(0.5rem, env(safe-area-inset-bottom));
    background: rgba(253, 248, 243, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-top: 1px solid rgba(196, 149, 106, 0.15);
    box-shadow: 0 -4px 20px rgba(44, 36, 32, 0.06);
  }

  .bottom-tab {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    padding: 0.35rem 0.75rem;
    text-decoration: none;
    color: #9B8B7E;
    transition: all 0.3s;
    border-radius: 12px;
    position: relative;
  }

  .bottom-tab:active {
    transform: scale(0.92);
  }

  .bottom-tab.active {
    color: #C4956A;
  }

  .bottom-tab.active .tab-icon {
    transform: translateY(-2px);
  }

  .bottom-tab.active::before {
    content: '';
    position: absolute;
    top: -0.5rem;
    left: 50%;
    transform: translateX(-50%);
    width: 20px;
    height: 3px;
    background: linear-gradient(90deg, #C4956A, #D4AF37);
    border-radius: 2px;
  }

  .tab-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    transition: transform 0.3s;
  }

  .tab-label {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.5px;
  }
</style>

<script>
  // Detect current path and highlight active tab
  const currentPath = window.location.pathname;
  const tabs = document.querySelectorAll('.bottom-tab');
  tabs.forEach(tab => {
    const href = tab.getAttribute('data-href');
    if (href === '/') {
      if (currentPath === '/' || currentPath === '/index.html') {
        tab.classList.add('active');
      }
    } else if (currentPath.startsWith(href)) {
      tab.classList.add('active');
    }
  });

  // Vibration feedback on click
  if (navigator.vibrate) {
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        navigator.vibrate(10);
      });
    });
  }
</script>
