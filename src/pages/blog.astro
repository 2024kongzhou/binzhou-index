---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="文章博客 - 滨州索引">
  <Header />

  <main class="max-w-7xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-8">文章博客</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <article class="bg-white rounded-lg shadow overflow-hidden hover:shadow-lg transition">
        <div class="h-48 bg-gradient-to-br from-blue-400 to-blue-600"></div>
        <div class="p-4">
          <span class="text-xs text-blue-600">博客</span>
          <h3 class="font-bold mt-2 mb-2">文章标题</h3>
          <p class="text-gray-600 text-sm">文章摘要内容...</p>
        </div>
      </article>
    </div>
  </main>

  <Footer />
</Layout>