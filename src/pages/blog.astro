---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = [...new Set(posts.map(post => post.data.category))];
---

<Layout title="文章博客 - 滨州索引" description="滨州地名志、城市发展、文化传承、人文景观等文章">
  <Header />

  <main class="max-w-7xl mx-auto px-4 py-8">
    <!-- 面包屑导航 -->
    <nav aria-label="面包屑导航" class="text-sm text-gray-500 mb-6">
      <ol class="flex items-center space-x-2">
        <li><a href="/" class="hover:text-primary">首页</a></li>
        <li><span class="text-gray-400">/</span></li>
        <li aria-current="page" class="text-gray-800">文章博客</li>
      </ol>
    </nav>

    <!-- 页面标题 -->
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">文章博客</h1>
      <p class="text-lg text-gray-600">探索滨州的历史文化、城市发展与人文景观</p>
    </div>

    <!-- 分类筛选 -->
    <div class="mb-8">
      <div class="flex flex-wrap gap-2 justify-center">
        <button class="category-btn px-4 py-2 bg-primary text-white rounded-full text-sm" data-category="all">全部</button>
        {categories.map(category => (
          <button class="category-btn px-4 py-2 bg-gray-200 rounded-full text-sm hover:bg-gray-300 transition" data-category={category}>
            {category}
          </button>
        ))}
      </div>
    </div>

    <!-- 文章列表 -->
    <div id="posts-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {sortedPosts.map(post => (
        <article class="blog-card bg-white rounded-lg shadow overflow-hidden hover:shadow-lg transition" data-category={post.data.category}>
          <a href={`/blog/${post.slug}`} class="block">
            <!-- 文章封面 -->
            <div class="h-48 bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center">
              <div class="text-white text-center p-4">
                <div class="text-5xl mb-2">
                  {post.data.category === '地名文化' && '📖'}
                  {post.data.category === '城市发展' && '🏙️'}
                  {post.data.category === '人文景观' && '🏛️'}
                  {post.data.category === '文化传承' && '🎭'}
                </div>
              </div>
            </div>
            <div class="p-6">
              <div class="flex items-center gap-2 mb-3">
                <span class="px-2 py-1 bg-blue-100 text-blue-700 text-xs rounded-full">{post.data.category}</span>
                <time class="text-xs text-gray-500" datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('zh-CN')}
                </time>
              </div>
              <h2 class="text-xl font-bold text-gray-900 mb-2 line-clamp-2">{post.data.title}</h2>
              <p class="text-gray-600 text-sm line-clamp-3 mb-4">{post.data.description}</p>
              <div class="flex items-center justify-between">
                <span class="text-sm text-gray-500">作者：{post.data.author}</span>
                <span class="text-primary text-sm font-medium">阅读更多 →</span>
              </div>
            </div>
          </a>
        </article>
      ))}
    </div>

    <!-- 无结果提示 -->
    <div id="no-results" class="hidden text-center py-16">
      <p class="text-gray-500 text-lg">该分类下暂无文章</p>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  const categoryBtns = document.querySelectorAll('.category-btn');
  const blogCards = document.querySelectorAll('.blog-card');
  const noResults = document.getElementById('no-results');

  categoryBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      // 更新按钮状态
      categoryBtns.forEach(b => {
        b.classList.remove('bg-primary', 'text-white');
        b.classList.add('bg-gray-200');
      });
      btn.classList.remove('bg-gray-200');
      btn.classList.add('bg-primary', 'text-white');

      // 筛选文章
      const category = btn.dataset.category;
      let visibleCount = 0;

      blogCards.forEach(card => {
        if (category === 'all' || card.dataset.category === category) {
          card.classList.remove('hidden');
          visibleCount++;
        } else {
          card.classList.add('hidden');
        }
      });

      // 显示/隐藏无结果提示
      if (visibleCount === 0) {
        noResults.classList.remove('hidden');
      } else {
        noResults.classList.add('hidden');
      }
    });
  });
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
