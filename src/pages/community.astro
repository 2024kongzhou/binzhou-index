---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="滨州小区索引 - 滨州索引">
  <Header />

  <main class="max-w-7xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-8">滨州小区索引</h1>

    <div class="mb-8">
      <input
        type="text"
        placeholder="搜索小区名称..."
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
      />
    </div>

    <div class="mb-4 flex flex-wrap gap-2">
      <span class="text-gray-600">首字母：</span>
      <button class="px-3 py-1 bg-primary text-white rounded text-sm">A</button>
      <button class="px-3 py-1 bg-gray-200 rounded text-sm hover:bg-gray-300">B</button>
      <button class="px-3 py-1 bg-gray-200 rounded text-sm hover:bg-gray-300">C</button>
      <button class="px-3 py-1 bg-gray-200 rounded text-sm hover:bg-gray-300">D</button>
      <button class="px-3 py-1 bg-gray-200 rounded text-sm hover:bg-gray-300">E</button>
      <button class="px-3 py-1 bg-gray-200 rounded text-sm hover:bg-gray-300">F</button>
      <button class="px-3 py-1 bg-gray-200 rounded text-sm hover:bg-gray-300">G</button>
      <button class="px-3 py-1 bg-gray-200 rounded text-sm hover:bg-gray-300">H</button>
      <button class="px-3 py-1 bg-gray-200 rounded text-sm hover:bg-gray-300">...</button>
    </div>

    <div class="text-center py-16 text-gray-500">
      <p class="text-lg">🏘️ 小区数据爬取中...</p>
      <p class="mt-2">请提供数据源URL进行爬取</p>
    </div>
  </main>

  <Footer />
</Layout>