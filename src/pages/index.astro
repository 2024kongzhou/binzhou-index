---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';
import villagesData from '../data/villages.json';

const totalVillages = villagesData.length;
const counties = [...new Set(villagesData.map(v => v.county))];
const surnameCount = new Set(villagesData.flatMap(v => v.surnames ? v.surnames.split(/[、,，]/) : [])).size;
const featuredVillages = villagesData.filter(v => v.established && v.established.includes('明')).slice(0, 6);

// Hot search tags
const hotTags = ['王姓', '李姓', '张姓', '刘姓', '洪武', '枣强', '移民'];
---

<Layout title="滨州索引 - 滨州地名志高端门户网站">
  <Header />

  <main>
    <!-- Hero Section -->
    <section class="hero-section">
      <!-- Surname Background Animation -->
      <div class="surname-bg" id="surname-bg"></div>

      <!-- Decorative Rings -->
      <div class="hero-rings">
        <div class="ring ring-1"></div>
        <div class="ring ring-2"></div>
        <div class="ring ring-3"></div>
      </div>

      <div class="hero-content">
        <div class="hero-badge fade-in">地名文化</div>
        <h1 class="hero-title fade-in">
          <span class="gradient-text">探寻每一寸土地的记忆</span>
        </h1>
        <p class="hero-desc fade-in">
          收录滨州 {totalVillages} 个村庄地名历史，追溯六百年移民源流
        </p>
        <div class="hero-actions fade-in">
          <a href="/place" class="hero-btn hero-btn-primary">探索地名志</a>
          <a href="/blog" class="hero-btn hero-btn-secondary">阅读文章</a>
        </div>
      </div>
    </section>

    <!-- Search Section -->
    <section class="search-section fade-in">
      <div class="search-float">
        <form action="/place" method="get" class="search-form">
          <div class="search-input-wrap">
            <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            <input
              type="text"
              name="search"
              id="hero-search"
              placeholder="搜索村庄名、姓氏、历史事件..."
              autocomplete="off"
            />
            <button type="button" id="search-clear" class="search-clear hidden" aria-label="清空搜索">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </button>
            <button type="submit" class="search-submit">搜索</button>
          </div>
          <!-- Suggestions -->
          <div id="search-suggestions" class="search-suggestions hidden"></div>
        </form>
        <!-- Hot Tags -->
        <div class="hot-tags">
          <span class="hot-tag-label">热门:</span>
          {hotTags.map(tag => (
            <a href={`/place?search=${encodeURIComponent(tag)}`} class="hot-tag">{tag}</a>
          ))}
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section fade-in">
      <div class="stats-scroll">
        <div class="stats-inner">
          <div class="stat-card">
            <div class="stat-num">{totalVillages}</div>
            <div class="stat-label">收录村庄</div>
          </div>
          <div class="stat-card">
            <div class="stat-num">{counties.length}</div>
            <div class="stat-label">覆盖县区</div>
          </div>
          <div class="stat-card">
            <div class="stat-num">600+</div>
            <div class="stat-label">历史年份</div>
          </div>
          <div class="stat-card">
            <div class="stat-num">{surnameCount}+</div>
            <div class="stat-label">姓氏源流</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Core Sections -->
    <section class="core-section fade-in">
      <div class="section-header">
        <h2 class="section-title">核心板块</h2>
        <p class="section-desc">全方位探索滨州</p>
      </div>
      <div class="core-scroll">
        <div class="core-inner">
          <a href="/place" class="core-card">
            <div class="core-card-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"></path>
                <circle cx="12" cy="9" r="2.5"></circle>
              </svg>
            </div>
            <h3 class="core-card-title">地名志</h3>
            <p class="core-card-desc">收录{totalVillages}个村庄历史</p>
          </a>
          <a href="/community" class="core-card">
            <div class="core-card-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                <polyline points="9 22 9 12 15 12 15 22"></polyline>
              </svg>
            </div>
            <h3 class="core-card-title">小区索引</h3>
            <p class="core-card-desc">滨城区小区信息一览</p>
          </a>
          <a href="/tutorial" class="core-card">
            <div class="core-card-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
              </svg>
            </div>
            <h3 class="core-card-title">装修教程</h3>
            <p class="core-card-desc">窗帘安装与经营技巧</p>
          </a>
          <a href="/product" class="core-card">
            <div class="core-card-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
                <path d="M16 7V5a4 4 0 0 0-8 0v2"></path>
              </svg>
            </div>
            <h3 class="core-card-title">产品展示</h3>
            <p class="core-card-desc">窗帘墙布软装产品</p>
          </a>
        </div>
      </div>
    </section>

    <!-- Featured Villages Timeline -->
    <section class="featured-section fade-in">
      <div class="section-header">
        <h2 class="section-title">重点村庄</h2>
        <p class="section-desc">明代移民建村，历史悠久</p>
      </div>
      <div class="timeline">
        {featuredVillages.map((village, i) => (
          <a href={`/place/${village.id}`} class={`timeline-item ${i % 2 === 0 ? 'left' : 'right'}`}>
            <div class="timeline-dot"></div>
            <div class="timeline-card">
              <div class="timeline-era">{village.established}代</div>
              <h3 class="timeline-name">{village.name}</h3>
              <p class="timeline-loc">{village.county} · {village.town}</p>
              <p class="timeline-desc">{village.history ? village.history.substring(0, 80) + '...' : ''}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="section-footer">
        <a href="/place" class="section-btn">查看全部村庄</a>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section fade-in">
      <div class="cta-content">
        <h2 class="cta-title">一起守护地名文化</h2>
        <p class="cta-desc">每一个村庄名都承载着先辈的记忆，值得被记录和传承</p>
        <a href="/place" class="cta-btn">开始探索</a>
      </div>
    </section>
  </main>

  <Footer />
  <BottomNav />
</Layout>

<style>
  /* Hero Section */
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: linear-gradient(180deg, #FDF8F3 0%, #F9F2EA 100%);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 6rem 1.5rem 4rem;
    max-width: 700px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.75rem;
    letter-spacing: 3px;
    color: #C4956A;
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  .hero-badge::before {
    content: '';
    width: 30px;
    height: 1px;
    background: #C4956A;
  }

  .hero-badge::after {
    content: '';
    width: 30px;
    height: 1px;
    background: #C4956A;
  }

  .hero-title {
    font-family: 'Noto Serif SC', serif;
    font-size: clamp(2rem, 8vw, 3.5rem);
    font-weight: 900;
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }

  .hero-desc {
    font-size: 1.05rem;
    color: #6B5D54;
    line-height: 1.8;
    margin-bottom: 2.5rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    border-radius: 50px;
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .hero-btn-primary {
    background: linear-gradient(135deg, #C4956A, #D4AF37);
    color: white;
    box-shadow: 0 4px 16px rgba(196, 149, 106, 0.4);
  }

  .hero-btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(196, 149, 106, 0.5);
  }

  .hero-btn-secondary {
    background: transparent;
    color: #6B5D54;
    border: 1px solid rgba(196, 149, 106, 0.3);
  }

  .hero-btn-secondary:hover {
    border-color: #C4956A;
    color: #C4956A;
    transform: translateY(-2px);
  }

  /* Decorative Rings */
  .hero-rings {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 1;
  }

  .ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(196, 149, 106, 0.08);
  }

  .ring-1 {
    width: 300px;
    height: 300px;
    animation: ringPulse 6s ease-in-out infinite;
  }

  .ring-2 {
    width: 500px;
    height: 500px;
    animation: ringPulse 8s ease-in-out infinite 1s;
  }

  .ring-3 {
    width: 700px;
    height: 700px;
    animation: ringPulse 10s ease-in-out infinite 2s;
  }

  @keyframes ringPulse {
    0%, 100% { transform: scale(1); opacity: 0.5; }
    50% { transform: scale(1.05); opacity: 1; }
  }

  /* Search Section */
  .search-section {
    position: relative;
    z-index: 10;
    padding: 0 1.5rem;
    margin-top: -3rem;
  }

  .search-float {
    max-width: 640px;
    margin: 0 auto;
    background: #FFFFFF;
    border: 1px solid rgba(196, 149, 106, 0.15);
    border-radius: 24px;
    padding: 1.25rem;
    box-shadow: 0 12px 40px rgba(44, 36, 32, 0.1);
  }

  .search-form {
    position: relative;
  }

  .search-input-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: #FDF8F3;
    border-radius: 16px;
    padding: 0.5rem 0.5rem 0.5rem 1rem;
    border: 1px solid transparent;
    transition: border-color 0.3s;
  }

  .search-input-wrap:focus-within {
    border-color: rgba(196, 149, 106, 0.3);
  }

  .search-icon {
    color: #C4956A;
    flex-shrink: 0;
  }

  .search-input-wrap input {
    flex: 1;
    background: none;
    border: none;
    font-size: 0.95rem;
    color: #2C2420;
    font-family: 'Noto Sans SC', sans-serif;
    outline: none;
    min-width: 0;
  }

  .search-input-wrap input::placeholder {
    color: #9B8B7E;
  }

  .search-clear {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(196, 149, 106, 0.1);
    border: none;
    cursor: pointer;
    color: #9B8B7E;
    transition: all 0.3s;
    flex-shrink: 0;
  }

  .search-clear:hover {
    background: rgba(196, 149, 106, 0.2);
    color: #C4956A;
  }

  .search-clear.hidden {
    display: none;
  }

  .search-submit {
    padding: 0.625rem 1.25rem;
    background: linear-gradient(135deg, #C4956A, #D4AF37);
    color: white;
    border: none;
    border-radius: 12px;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s;
    flex-shrink: 0;
    font-family: 'Noto Sans SC', sans-serif;
  }

  .search-submit:hover {
    box-shadow: 0 4px 12px rgba(196, 149, 106, 0.4);
  }

  .search-suggestions {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    margin-top: 0.5rem;
    background: #FFFFFF;
    border: 1px solid rgba(196, 149, 106, 0.15);
    border-radius: 16px;
    box-shadow: 0 12px 40px rgba(44, 36, 32, 0.1);
    max-height: 240px;
    overflow-y: auto;
    z-index: 20;
  }

  .search-suggestions.hidden {
    display: none;
  }

  .suggestion-item {
    display: block;
    padding: 0.75rem 1rem;
    text-decoration: none;
    color: #2C2420;
    font-size: 0.9rem;
    border-bottom: 1px solid rgba(196, 149, 106, 0.08);
    transition: background 0.2s;
  }

  .suggestion-item:last-child {
    border-bottom: none;
  }

  .suggestion-item:hover {
    background: rgba(196, 149, 106, 0.05);
  }

  .suggestion-item .sug-name {
    font-weight: 600;
  }

  .suggestion-item .sug-loc {
    font-size: 0.8rem;
    color: #9B8B7E;
    margin-left: 0.5rem;
  }

  .hot-tags {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }

  .hot-tag-label {
    font-size: 0.8rem;
    color: #9B8B7E;
  }

  .hot-tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: rgba(196, 149, 106, 0.08);
    border-radius: 20px;
    font-size: 0.8rem;
    color: #6B5D54;
    text-decoration: none;
    transition: all 0.3s;
  }

  .hot-tag:hover {
    background: rgba(196, 149, 106, 0.15);
    color: #C4956A;
  }

  /* Stats Section */
  .stats-section {
    padding: 2rem 0;
  }

  .stats-scroll {
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .stats-scroll::-webkit-scrollbar {
    display: none;
  }

  .stats-inner {
    display: flex;
    gap: 1rem;
    padding: 0 1.5rem;
    min-width: max-content;
  }

  .stat-card {
    min-width: 140px;
    background: #FFFFFF;
    border: 1px solid rgba(196, 149, 106, 0.1);
    border-radius: 24px;
    padding: 1.5rem 1.25rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .stat-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #C4956A, #D4AF37);
  }

  .stat-num {
    font-family: 'Noto Serif SC', serif;
    font-size: 2rem;
    font-weight: 900;
    background: linear-gradient(135deg, #C4956A, #D4AF37);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.8rem;
    color: #9B8B7E;
    margin-top: 0.5rem;
    letter-spacing: 1px;
  }

  /* Core Section */
  .core-section {
    padding: 3rem 0;
  }

  .section-header {
    text-align: center;
    padding: 0 1.5rem;
    margin-bottom: 2rem;
  }

  .section-title {
    font-family: 'Noto Serif SC', serif;
    font-size: 1.75rem;
    font-weight: 900;
    color: #2C2420;
    margin-bottom: 0.5rem;
  }

  .section-desc {
    font-size: 0.95rem;
    color: #9B8B7E;
  }

  .core-scroll {
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .core-scroll::-webkit-scrollbar {
    display: none;
  }

  .core-inner {
    display: flex;
    gap: 1rem;
    padding: 0 1.5rem;
    min-width: max-content;
  }

  .core-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    min-width: 160px;
    padding: 2rem 1.5rem;
    background: #FFFFFF;
    border: 1px solid rgba(196, 149, 106, 0.1);
    border-radius: 24px;
    text-decoration: none;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }

  .core-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #C4956A, #D4AF37);
    transform: scaleX(0);
    transition: transform 0.3s;
  }

  .core-card:hover::before {
    transform: scaleX(1);
  }

  .core-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(44, 36, 32, 0.1);
  }

  .core-card-icon {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    background: linear-gradient(135deg, rgba(196, 149, 106, 0.1), rgba(212, 175, 55, 0.08));
    display: flex;
    align-items: center;
    justify-content: center;
    color: #C4956A;
    margin-bottom: 1rem;
  }

  .core-card-title {
    font-family: 'Noto Serif SC', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #2C2420;
    margin-bottom: 0.5rem;
  }

  .core-card-desc {
    font-size: 0.8rem;
    color: #9B8B7E;
    line-height: 1.5;
  }

  /* Featured Villages Timeline */
  .featured-section {
    padding: 3rem 1.5rem;
    background: linear-gradient(180deg, #FDF8F3 0%, #F9F2EA 100%);
  }

  .timeline {
    position: relative;
    max-width: 700px;
    margin: 0 auto;
    padding: 1rem 0;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 20px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(180deg, #C4956A, #D4AF37, rgba(196, 149, 106, 0.2));
  }

  .timeline-item {
    position: relative;
    display: block;
    padding-left: 52px;
    margin-bottom: 2rem;
    text-decoration: none;
  }

  .timeline-item:last-child {
    margin-bottom: 0;
  }

  .timeline-dot {
    position: absolute;
    left: 13px;
    top: 1.25rem;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #FDF8F3;
    border: 3px solid #C4956A;
    z-index: 1;
  }

  .timeline-card {
    background: #FFFFFF;
    border: 1px solid rgba(196, 149, 106, 0.1);
    border-radius: 20px;
    padding: 1.25rem;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }

  .timeline-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: linear-gradient(180deg, #C4956A, #D4AF37);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .timeline-item:hover .timeline-card {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(44, 36, 32, 0.08);
  }

  .timeline-item:hover .timeline-card::before {
    opacity: 1;
  }

  .timeline-era {
    display: inline-flex;
    padding: 0.2rem 0.6rem;
    background: linear-gradient(135deg, rgba(196, 149, 106, 0.12), rgba(212, 175, 55, 0.08));
    border-radius: 10px;
    font-size: 0.75rem;
    color: #C4956A;
    font-weight: 500;
    margin-bottom: 0.5rem;
  }

  .timeline-name {
    font-family: 'Noto Serif SC', serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: #2C2420;
    margin-bottom: 0.25rem;
  }

  .timeline-loc {
    font-size: 0.8rem;
    color: #9B8B7E;
    margin-bottom: 0.5rem;
  }

  .timeline-desc {
    font-size: 0.85rem;
    color: #6B5D54;
    line-height: 1.7;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .section-footer {
    text-align: center;
    margin-top: 2.5rem;
  }

  .section-btn {
    display: inline-flex;
