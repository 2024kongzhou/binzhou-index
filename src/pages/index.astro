<script define:vars={{ villagesData, hotTags }}>
  // Surname background animation
  const surnames = '赵钱孙李周吴郑王冯陈褚卫蒋沈韩杨朱秦尤许何吕施张孔曹严华金魏陶姜戚谢邹喻柏水窦章云苏潘葛奚范彭郎鲁韦昌马苗凤花方俞任袁柳酆鲍史唐费廉岑薛雷贺倪汤滕殷罗毕郝邬安常乐于时傅皮卞齐康伍余元卜顾孟平黄和穆萧尹姚邵湛汪祁毛禹狄米贝明臧计伏成戴谈宋茅庞熊纪舒屈项祝董梁杜阮蓝闵席季麻强贾路娄危江童颜郭梅盛林刁钟徐邱骆高夏蔡田樊胡凌霍虞万支柯昝管卢莫经房裘缪干解应宗丁宣贲邓郁单杭洪包诸左石崔吉钮龚程嵇邢滑裴陆荣翁荀羊於惠甄曲家封芮羿储靳汲邴糜松井段富巫乌焦巴弓牧隗山谷车侯宓蓬全郗班仰秋仲伊宫宁仇栾暴甘钭厉戎祖武符刘景詹束龙叶幸司韶郜黎蓟薄印宿白怀蒲邰从鄂索咸籍赖卓蔺屠蒙池乔阴郁胥能苍双闻莘党翟谭贡劳逄姬申扶堵冉宰郦雍却璩桑桂濮牛寿通边扈燕冀郏浦尚农温别庄晏柴瞿阎充慕连茹习宦艾鱼容向古易慎戈廖庾终暨居衡步都耿满弘匡国文寇广禄阙东欧殳沃利蔚越夔隆师巩厍聂晁勾敖融冷訾辛阚那简饶空曾母沙乜养鞠须丰巢关蒯相查后荆红游竺权逯盖益桓公';
  const surnameBg = document.getElementById('surname-bg');
  if (surnameBg) {
    for (let i = 0; i < 30; i++) {
      const char = document.createElement('span');
      char.className = 'surname-char';
      char.textContent = surnames[Math.floor(Math.random() * surnames.length)];
      char.style.left = Math.random() * 100 + '%';
      char.style.fontSize = (Math.random() * 3 + 1.5) + 'rem';
      char.style.animationDuration = (Math.random() * 15 + 15) + 's';
      char.style.animationDelay = (Math.random() * 20) + 's';
      surnameBg.appendChild(char);
    }
  }

  // Search suggestions
  const searchInput = document.getElementById('hero-search');
  const searchClear = document.getElementById('search-clear');
  const suggestionsEl = document.getElementById('search-suggestions');

  if (searchInput && suggestionsEl) {
    searchInput.addEventListener('input', () => {
      const val = searchInput.value.trim().toLowerCase();
      if (val.length === 0) {
        suggestionsEl.classList.add('hidden');
        searchClear?.classList.add('hidden');
        return;
      }
      searchClear?.classList.remove('hidden');

      const matches = villagesData.filter(v =>
        v.name.toLowerCase().includes(val) ||
        (v.pinyin && v.pinyin.toLowerCase().includes(val)) ||
        (v.county && v.county.toLowerCase().includes(val)) ||
        (v.surnames && v.surnames.toLowerCase().includes(val))
      ).slice(0, 8);

      if (matches.length === 0) {
        suggestionsEl.classList.add('hidden');
        return;
      }

      suggestionsEl.innerHTML = matches.map(v =>
        `<a href="/place/${v.id}" class="suggestion-item"><span class="sug-name">${v.name}</span><span class="sug-loc">${v.county} · ${v.town}</span></a>`
      ).join('');
      suggestionsEl.classList.remove('hidden');
    });

    searchInput.addEventListener('blur', () => {
      setTimeout(() => suggestionsEl.classList.add('hidden'), 200);
    });

    searchInput.addEventListener('focus', () => {
      if (searchInput.value.trim().length > 0) {
        searchInput.dispatchEvent(new Event('input'));
      }
    });

    searchClear?.addEventListener('click', () => {
      searchInput.value = '';
      suggestionsEl.classList.add('hidden');
      searchClear.classList.add('hidden');
      searchInput.focus();
    });
  }
</script>
