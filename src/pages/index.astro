---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import villagesData from '../data/villages.json';

const totalVillages = villagesData.length;
const counties = [...new Set(villagesData.map(v => v.county))];
const featuredVillages = villagesData.filter(v => v.established && ['夏', '商', '周', '秦', '汉'].includes(v.established)).slice(0, 6);
---

<Layout title="滨州索引 - 滨州地名志高端门户网站">
  <Header />

  <main>
    <!-- Hero Section -->
    <section class="bg-gradient-to-r from-primary to-secondary text-white py-20">
      <div class="max-w-7xl mx-auto px-4 text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">滨州索引</h1>
        <p class="text-xl mb-8">滨州地名志高端门户网站</p>
        <p class="text-lg opacity-90">收录滨州 {totalVillages} 个村庄地名历史</p>
      </div>
    </section>

    <!-- Search Section -->
    <section class="max-w-3xl mx-auto px-4 -mt-8">
      <div class="bg-white rounded-lg shadow-lg p-6">
        <form action="/place" method="get" class="relative">
          <input
            type="text"
            name="search"
            placeholder="搜索村庄名、姓氏、历史..."
            class="w-full px-4 py-3 pl-12 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
          />
          <svg class="absolute left-4 top-3.5 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          <button type="submit" class="absolute right-2 top-2 px-4 py-1.5 bg-primary text-white rounded hover:bg-primary/90 transition">
            搜索
          </button>
        </form>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="max-w-7xl mx-auto px-4 py-12">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div class="bg-white rounded-lg shadow p-6">
          <div class="text-3xl font-bold text-primary">{totalVillages}</div>
          <div class="text-gray-600 mt-2">收录村庄</div>
        </div>
        <div class="bg-white rounded-lg shadow p-6">
          <div class="text-3xl font-bold text-primary">{counties.length}</div>
          <div class="text-gray-600 mt-2">覆盖县区</div>
        </div>
        <div class="bg-white rounded-lg shadow p-6">
          <div class="text-3xl font-bold text-primary">{villagesData.filter(v => v.history && v.history.length > 10).length.toLocaleString()}+</div>
          <div class="text-gray-600 mt-2">历史记录</div>
        </div>
        <div class="bg-white rounded-lg shadow p-6">
          <div class="text-3xl font-bold text-primary">{new Set(villagesData.flatMap(v => v.surnames ? v.surnames.split("、") : [])).size}+</div>
          <div class="text-gray-600 mt-2">姓氏源流</div>
        </div>
      </div>
    </section>

    <!-- Features Grid -->
    <section class="max-w-7xl mx-auto px-4 py-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <a href="/place" class="block p-6 bg-white rounded-lg shadow hover:shadow-lg transition">
          <div class="text-3xl mb-3">📖</div>
          <h3 class="text-lg font-bold mb-2">滨州地名志</h3>
          <p class="text-gray-600 text-sm">收录滨州{totalVillages}个村庄地名历史</p>
        </a>

        <a href="/community" class="block p-6 bg-white rounded-lg shadow hover:shadow-lg transition">
          <div class="text-3xl mb-3">🏘️</div>
          <h3 class="text-lg font-bold mb-2">滨州小区</h3>
          <p class="text-gray-600 text-sm">滨城区小区信息一览</p>
        </a>

        <a href="/tutorial" class="block p-6 bg-white rounded-lg shadow hover:shadow-lg transition">
          <div class="text-3xl mb-3">📝</div>
          <h3 class="text-lg font-bold mb-2">装修教程</h3>
          <p class="text-gray-600 text-sm">窗帘安装、门店经营技巧</p>
        </a>

        <a href="/product" class="block p-6 bg-white rounded-lg shadow hover:shadow-lg transition">
          <div class="text-3xl mb-3">🖼️</div>
          <h3 class="text-lg font-bold mb-2">产品展示</h3>
          <p class="text-gray-600 text-sm">窗帘墙布软装产品</p>
        </a>
      </div>
    </section>

    <!-- Featured Villages -->
    <section class="bg-gray-100 py-16">
      <div class="max-w-7xl mx-auto px-4">
        <h2 class="text-2xl font-bold mb-2">重点村庄推荐</h2>
        <p class="text-gray-600 mb-8">历史悠久、文化底蕴深厚的古老村庄</p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredVillages.map(village => (
            <a href={`/place/${village.id}`} class="block bg-white rounded-lg shadow hover:shadow-lg transition overflow-hidden">
              <div class="h-32 bg-gradient-to-r from-amber-100 to-orange-100 flex items-center justify-center">
                <span class="text-4xl">🏛️</span>
              </div>
              <div class="p-4">
                <div class="flex justify-between items-start mb-2">
                  <h3 class="font-bold text-lg">{village.name}</h3>
                  <span class="px-2 py-0.5 bg-amber-100 text-amber-800 text-xs rounded">{village.established}</span>
                </div>
                <p class="text-sm text-gray-500 mb-2">{village.county} · {village.town}</p>
                <p class="text-sm text-gray-600 line-clamp-2">{village.history}</p>
              </div>
            </a>
          ))}
        </div>
        <div class="text-center mt-8">
          <a href="/place" class="inline-block px-6 py-3 bg-primary text-white rounded-lg hover:bg-primary/90 transition">
            查看全部村庄
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>