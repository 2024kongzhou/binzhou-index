---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="滨州索引 - 滨州地名志高端门户网站">
  <Header />

  <main>
    <!-- Hero Section -->
    <section class="bg-gradient-to-r from-primary to-secondary text-white py-20">
      <div class="max-w-7xl mx-auto px-4 text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">滨州索引</h1>
        <p class="text-xl mb-8">滨州地名志高端门户网站</p>
        <p class="text-lg opacity-90">收录滨州地名志、小区索引、装修教程、产品展示</p>
      </div>
    </section>

    <!-- Search Section -->
    <section class="max-w-3xl mx-auto px4 -mt-8">
      <div class="bg-white rounded-lg shadow-lg p-6">
        <input
          type="text"
          placeholder="搜索地名、小区、文章..."
          class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
        />
      </div>
    </section>

    <!-- Features Grid -->
    <section class="max-w-7xl mx-auto px-4 py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <a href="/place" class="block p-6 bg-white rounded-lg shadow hover:shadow-lg transition">
          <div class="text-3xl mb-3">📖</div>
          <h3 class="text-lg font-bold mb-2">滨州地名志</h3>
          <p class="text-gray-600 text-sm">收录滨州306个村庄地名历史</p>
        </a>

        <a href="/community" class="block p-6 bg-white rounded-lg shadow hover:shadow-lg transition">
          <div class="text-3xl mb-3">🏘️</div>
          <h3 class="text-lg font-bold mb-2">滨州小区</h3>
          <p class="text-gray-600 text-sm">滨城区小区信息一览</p>
        </a>

        <a href="/tutorial" class="block p-6 bg-white rounded-lg shadow hover:shadow-lg transition">
          <div class="text-3xl mb-3">📝</div>
          <h3 class="text-lg font-bold mb-2">装修教程</h3>
          <p class="text-gray-600 text-sm">窗帘安装、门店经营技巧</p>
        </a>

        <a href="/product" class="block p-6 bg-white rounded-lg shadow hover:shadow-lg transition">
          <div class="text-3xl mb-3">🖼️</div>
          <h3 class="text-lg font-bold mb-2">产品展示</h3>
          <p class="text-gray-600 text-sm">窗帘墙布软装产品</p>
        </a>
      </div>
    </section>

    <!-- Latest Articles -->
    <section class="bg-gray-100 py-16">
      <div class="max-w-7xl mx-auto px-4">
        <h2 class="text-2xl font-bold mb-8">最新文章</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <article class="bg-white rounded-lg shadow overflow-hidden">
            <div class="h-48 bg-gray-300"></div>
            <div class="p-4">
              <h3 class="font-bold mb-2">文章标题</h3>
              <p class="text-gray-600 text-sm">文章摘要...</p>
            </div>
          </article>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>