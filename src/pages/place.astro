---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="滨州地名志 - 滨州索引">
  <Header />

  <main class="max-w-7xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-8">滨州地名志</h1>

    <div class="mb-8">
      <input
        type="text"
        id="search-input"
        placeholder="搜索地名、姓氏、历史事件..."
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
      />
    </div>

    <div class="mb-8 flex flex-wrap gap-2">
      <button class="px-4 py-2 bg-primary text-white rounded">全部</button>
      <button class="px-4 py-2 bg-gray-200 rounded hover:bg-gray-300">尚店乡</button>
      <button class="px-4 py-2 bg-gray-200 rounded hover:bg-gray-300">张集乡</button>
      <button class="px-4 py-2 bg-gray-200 rounded hover:bg-gray-300">单寺乡</button>
      <button class="px-4 py-2 bg-gray-200 rounded hover:bg-gray-300">梁才乡</button>
      <button class="px-4 py-2 bg-gray-200 rounded hover:bg-gray-300">蒲城乡</button>
      <button class="px-4 py-2 bg-gray-200 rounded hover:bg-gray-300">彭李乡</button>
      <button class="px-4 py-2 bg-gray-200 rounded hover:bg-gray-300">郭集乡</button>
    </div>

    <div class="text-center py-16 text-gray-500">
      <p class="text-lg">📖 地名志数据整理中...</p>
      <p class="mt-2">请等待数据导入</p>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  const searchInput = document.getElementById('search-input');
  searchInput?.addEventListener('input', (e) => {
    console.log('搜索:', (e.target as HTMLInputElement).value);
  });
</script>