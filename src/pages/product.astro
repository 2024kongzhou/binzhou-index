---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import products from '../data/products.json';

const categories = [...new Set(products.map(p => p.category))];
---

<Layout title="产品展示 - 滨州索引" description="窗帘、墙布、软装产品展示，简约现代、中式复古、高档绒布等多种风格">
  <Header />

  <main class="max-w-7xl mx-auto px-4 py-8">
    <!-- 面包屑导航 -->
    <nav aria-label="面包屑导航" class="text-sm text-gray-500 mb-6">
      <ol class="flex items-center space-x-2">
        <li><a href="/" class="hover:text-primary">首页</a></li>
        <li><span class="text-gray-400">/</span></li>
        <li aria-current="page" class="text-gray-800">产品展示</li>
      </ol>
    </nav>

    <!-- 页面标题 -->
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">产品展示</h1>
      <p class="text-lg text-gray-600">精选窗帘、墙布、软装产品，打造温馨舒适的家居环境</p>
    </div>

    <!-- 限时优惠提示 -->
    <div class="bg-gradient-to-r from-red-500 to-orange-500 text-white rounded-lg p-4 mb-8">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <div>
            <p class="font-semibold">限时优惠活动进行中</p>
            <p class="text-sm opacity-90">精选产品低至6.5折</p>
          </div>
        </div>
        <a href="/deals" class="bg-white text-red-500 px-4 py-2 rounded-lg font-medium hover:bg-gray-100 transition">
          查看优惠
        </a>
      </div>
    </div>

    <!-- 分类筛选 -->
    <div class="mb-8">
      <div class="flex flex-wrap gap-2 justify-center">
        <button class="category-btn px-4 py-2 bg-primary text-white rounded-full text-sm" data-category="all">全部</button>
        {categories.map(category => (
          <button class="category-btn px-4 py-2 bg-gray-200 rounded-full text-sm hover:bg-gray-300 transition" data-category={category}>
            {category}
          </button>
        ))}
      </div>
    </div>

    <!-- 产品列表 -->
    <div id="products-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {products.map(product => (
        <article class="product-card bg-white rounded-lg shadow overflow-hidden hover:shadow-lg transition" data-category={product.category}>
          <!-- 产品图片 -->
          <div class="h-48 bg-gradient-to-br from-gray-100 to-gray-200 flex items-center justify-center relative">
            <div class="text-center text-gray-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <span class="text-sm">{product.name}</span>
            </div>
            <span class="absolute top-2 right-2 px-2 py-1 bg-primary text-white text-xs rounded">
              {product.category}
            </span>
          </div>
          
          <div class="p-4">
            <h2 class="text-lg font-bold text-gray-900 mb-2">{product.name}</h2>
            <p class="text-gray-600 text-sm mb-3 line-clamp-2">{product.description}</p>
            
            <!-- 价格 -->
            <p class="text-xl font-bold text-primary mb-3">{product.price}</p>
            
            <!-- 特点标签 -->
            <div class="flex flex-wrap gap-1 mb-4">
              {product.features.slice(0, 3).map(feature => (
                <span class="px-2 py-1 bg-gray-100 text-gray-600 text-xs rounded">{feature}</span>
              ))}
            </div>
            
            <!-- 操作按钮 -->
            <div class="flex gap-2">
              <a href="tel:13326280320"
                class="flex-1 bg-primary text-white py-2 rounded text-sm font-medium hover:bg-primary/90 transition text-center block">
                📞 咨询购买
              </a>
              <a href="/deals"
                class="px-3 py-2 border border-gray-300 rounded text-sm text-gray-700 hover:bg-gray-50 transition text-center block">
                优惠详情
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- 无结果提示 -->
    <div id="no-results" class="hidden text-center py-16">
      <p class="text-gray-500 text-lg">该分类下暂无产品</p>
    </div>

    <!-- 服务说明 -->
    <div class="mt-16 grid grid-cols-1 md:grid-cols-4 gap-6">
      <div class="text-center p-6 bg-gray-50 rounded-lg">
        <div class="text-3xl mb-3">📏</div>
        <h3 class="font-bold mb-2">免费测量</h3>
        <p class="text-gray-600 text-sm">专业师傅上门测量</p>
      </div>
      <div class="text-center p-6 bg-gray-50 rounded-lg">
        <div class="text-3xl mb-3">🎨</div>
        <h3 class="font-bold mb-2">免费设计</h3>
        <p class="text-gray-600 text-sm">专业搭配建议</p>
      </div>
      <div class="text-center p-6 bg-gray-50 rounded-lg">
        <div class="text-3xl mb-3">🔧</div>
        <h3 class="font-bold mb-2">专业安装</h3>
        <p class="text-gray-600 text-sm">经验丰富的安装团队</p>
      </div>
      <div class="text-center p-6 bg-gray-50 rounded-lg">
        <div class="text-3xl mb-3">🛡️</div>
        <h3 class="font-bold mb-2">售后保障</h3>
        <p class="text-gray-600 text-sm">质量问题免费维修</p>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  const categoryBtns = document.querySelectorAll('.category-btn');
  const productCards = document.querySelectorAll('.product-card');
  const noResults = document.getElementById('no-results');

  categoryBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      // 更新按钮状态
      categoryBtns.forEach(b => {
        b.classList.remove('bg-primary', 'text-white');
        b.classList.add('bg-gray-200');
      });
      btn.classList.remove('bg-gray-200');
      btn.classList.add('bg-primary', 'text-white');

      // 筛选产品
      const category = btn.dataset.category;
      let visibleCount = 0;

      productCards.forEach(card => {
        if (category === 'all' || card.dataset.category === category) {
          card.classList.remove('hidden');
          visibleCount++;
        } else {
          card.classList.add('hidden');
        }
      });

      // 显示/隐藏无结果提示
      if (visibleCount === 0) {
        noResults.classList.remove('hidden');
      } else {
        noResults.classList.add('hidden');
      }
    });
  });
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
