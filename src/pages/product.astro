---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="产品展示 - 滨州索引">
  <Header />

  <main class="max-w-7xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-8">产品展示</h1>

    <div class="flex gap-4 mb-8">
      <button class="px-4 py-2 bg-primary text-white rounded">全部</button>
      <button class="px-4 py-2 bg-gray-200 rounded hover:bg-gray-300">窗帘</button>
      <button class="px-4 py-2 bg-gray-200 rounded hover:bg-gray-300">墙布</button>
      <button class="px-4 py-2 bg-gray-200 rounded hover:bg-gray-300">软装</button>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
      <div class="bg-white rounded-lg shadow overflow-hidden">
        <div class="h-48 bg-gray-200"></div>
        <div class="p-4">
          <h3 class="font-bold">产品名称</h3>
          <p class="text-gray-600 text-sm">产品描述</p>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>