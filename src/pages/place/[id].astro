---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import villagesData from '../../data/villages.json';

export function getStaticPaths() {
  return villagesData.map(village => ({
    params: { id: village.id },
    props: { village },
  }));
}

const { village } = Astro.props;
---

<Layout title={`${village.name} - 滨州地名志`}>
  <Header />

  <!-- 温暖色调样式 -->
  <style>
    .village-hero {
      background: linear-gradient(180deg, #FDF8F3 0%, #F9F2EA 100%);
      padding: 6rem 1.5rem 3rem;
      position: relative;
      overflow: hidden;
    }
    .village-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 20% 30%, rgba(196,149,106,0.08) 0%, transparent 40%),
        radial-gradient(circle at 80% 70%, rgba(212,175,55,0.06) 0%, transparent 35%);
    }
    .village-title-wrap { position: relative; z-index: 2; }
    .village-era-tag {
      font-size: 0.7rem;
      letter-spacing: 3px;
      color: #C4956A;
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-weight: 500;
    }
    .village-era-tag::before {
      content: '';
      width: 30px;
      height: 1px;
      background: #C4956A;
    }
    .village-name-title {
      font-family: 'Noto Serif SC', serif;
      font-size: clamp(2.5rem, 10vw, 3.5rem);
      font-weight: 900;
      line-height: 1.15;
      margin-bottom: 0.5rem;
    }
    .village-name-title .accent {
      background: linear-gradient(135deg, #C4956A, #D4AF37);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .village-pinyin {
      font-size: 1rem;
      color: #9B8B7E;
      letter-spacing: 2px;
      margin-bottom: 1.5rem;
    }
    .village-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    .meta-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 1rem;
      background: rgba(196,149,106,0.08);
      border-radius: 20px;
      font-size: 0.85rem;
      color: #6B5D54;
    }
    .meta-item svg { color: #C4956A; }
    .village-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 1.5rem;
      background: linear-gradient(135deg, #C4956A, #D4AF37);
      color: white;
      border-radius: 50px;
      font-weight: 600;
      font-size: 0.9rem;
      box-shadow: 0 8px 24px rgba(196,149,106,0.3);
    }
    .content-card {
      background: #FFFFFF;
      border: 1px solid rgba(196,149,106,0.1);
      border-radius: 24px;
      padding: 2rem;
      margin-bottom: 1.5rem;
      box-shadow: 0 4px 20px rgba(44,36,32,0.06);
      position: relative;
      overflow: hidden;
    }
    .content-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, #C4956A, #D4AF37);
    }
    .card-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1.5rem;
    }
    .card-icon {
      width: 40px;
      height: 40px;
      background: linear-gradient(135deg, rgba(196,149,106,0.12), rgba(212,175,55,0.08));
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #C4956A;
    }
    .card-title {
      font-family: 'Noto Serif SC', serif;
      font-size: 1.25rem;
      font-weight: 600;
      color: #2C2420;
    }
    .card-text {
      color: #6B5D54;
      line-height: 1.9;
      font-size: 0.95rem;
    }
    .surname-tag {
      padding: 0.5rem 1rem;
      background: linear-gradient(135deg, rgba(196,149,106,0.1), rgba(212,175,55,0.06));
      border: 1px solid rgba(196,149,106,0.2);
      border-radius: 20px;
      font-size: 0.85rem;
      color: #C4956A;
      font-weight: 500;
    }
    .back-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 1rem 2rem;
      background: linear-gradient(135deg, #C4956A, #D4AF37);
      color: white;
      border-radius: 50px;
      font-weight: 600;
      box-shadow: 0 8px 24px rgba(196,149,106,0.3);
      transition: transform 0.3s, box-shadow 0.3s;
    }
    .back-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 32px rgba(196,149,106,0.4);
    }
    .timeline {
      position: relative;
      padding-left: 2rem;
    }
    .timeline::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 2px;
      background: linear-gradient(to bottom, #E8C4A0, #C4956A, transparent);
    }
    .timeline-item {
      position: relative;
      padding: 1rem 0 1.5rem;
    }
    .timeline-item::before {
      content: '';
      position: absolute;
      left: -2rem;
      top: 1.25rem;
      width: 12px;
      height: 12px;
      background: #FDF8F3;
      border: 2px solid #C4956A;
      border-radius: 50%;
      transform: translateX(-5px);
    }
    .timeline-era {
      font-size: 0.75rem;
      letter-spacing: 2px;
      color: #C4956A;
      margin-bottom: 0.5rem;
      font-weight: 500;
    }
    .timeline-text {
      font-size: 0.9rem;
      color: #6B5D54;
      line-height: 1.8;
    }
  </style>

  <main class="village-page">
    <!-- Hero Section -->
    <section class="village-hero">
      <div class="village-title-wrap">
        <!-- 面包屑导航 -->
        <nav class="text-sm text-gray-500 mb-4">
          <a href="/" class="hover:text-primary">首页</a>
          <span class="mx-2">/</span>
          <a href="/place" class="hover:text-primary">滨州地名志</a>
          <span class="mx-2">/</span>
          <span>{village.name}</span>
        </nav>

        {village.established && (
          <div class="village-era-tag">
            始建于{village.established}
          </div>
        )}

        <h1 class="village-name-title">
          <span class="accent">{village.name}</span>
        </h1>

        {village.pinyin && (
          <div class="village-pinyin">{village.pinyin}</div>
        )}

        <div class="village-meta">
          <div class="meta-item">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
            </svg>
            {village.county} · {village.town}
          </div>
          {village.households && (
            <div class="meta-item">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
              </svg>
              {village.households}户
            </div>
          )}
          {village.area && (
            <div class="meta-item">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0121 18.382V7.618a1 1 0 01-.553-.894L15 7m0 13V7"></path>
              </svg>
              耕地{village.area}亩
            </div>
          )}
        </div>

        {village.established && (
          <div class="village-badge">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            {village.established}建村
          </div>
        )}
      </div>
    </section>

    <!-- Content Section -->
    <section class="village-content max-w-4xl mx-auto px-4 py-8" style="background: #FDF8F3;">
      <!-- 主要姓氏 -->
      {village.surnames && (
        <div class="content-card">
          <div class="card-header">
            <div class="card-icon">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <h2 class="card-title">主要姓氏</h2>
          </div>
          <div class="flex flex-wrap gap-2">
            {village.surnames.split('、').map(surname => (
              <span class="surname-tag">{surname}姓</span>
            ))}
          </div>
        </div>
      )}

      <!-- 地理位置 -->
      {village.location && (
        <div class="content-card">
          <div class="card-header">
            <div class="card-icon">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              </svg>
            </div>
            <h2 class="card-title">地理位置</h2>
          </div>
          <div class="card-text">
            <p>{village.location}</p>
          </div>
        </div>
      )}

      <!-- 建村历史 -->
      {village.fullHistory && (
        <div class="content-card">
          <div class="card-header">
            <div class="card-icon">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h2 class="card-title">建村历史</h2>
          </div>
          <div class="card-text">
            {village.fullHistory.split('\n').map(line => (
              <p>{line}</p>
            ))}
          </div>
        </div>
      )}

      <!-- 历史沿革 -->
      {village.evolution && (
        <div class="content-card">
          <div class="card-header">
            <div class="card-icon">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
              </svg>
            </div>
            <h2 class="card-title">历史沿革</h2>
          </div>
          <div class="timeline">
            {village.evolution.split('\n').filter(line => line.trim()).map(line => {
              const parts = line.split('：');
              const era = parts[0] ? parts[0].replace('时期', '') : '';
              const text = parts[1] || line;
              return (
                <div class="timeline-item">
                  <div class="timeline-era">{era}</div>
                  <div class="timeline-text">{text}</div>
                </div>
              );
            })}
          </div>
        </div>
      )}

      <!-- 民间传说 -->
      {village.legend && (
        <div class="content-card">
          <div class="card-header">
            <div class="card-icon">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path>
              </svg>
            </div>
            <h2 class="card-title">民间传说</h2>
          </div>
          <div class="card-text">
            {village.legend.split('\n').map(line => (
              <p>{line}</p>
            ))}
          </div>
        </div>
      )}

      <!-- 返回按钮 -->
      <div class="flex justify-center mt-8">
        <a href="/place" class="back-btn">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          返回村庄列表
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
