---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const tutorials = await getCollection('tutorial');
  return tutorials.map(tutorial => ({
    params: { slug: tutorial.slug },
    props: { tutorial },
  }));
}

const { tutorial } = Astro.props;
const { Content } = await tutorial.render();
const { title, description, category, pubDate, author, difficulty, duration, tags } = tutorial.data;
---

<Layout title={`${title} - 装修教程 - 滨州索引`} description={description}>
  <Header />
  <main class="max-w-4xl mx-auto px-4 py-8">
    <nav aria-label="面包屑导航" class="text-sm text-gray-500 mb-6">
      <ol class="flex items-center space-x-2">
        <li><a href="/" class="hover:text-primary">首页</a></li>
        <li><span class="text-gray-400">/</span></li>
        <li><a href="/tutorial" class="hover:text-primary">装修教程</a></li>
        <li><span class="text-gray-400">/</span></li>
        <li aria-current="page" class="text-gray-800">{title}</li>
      </ol>
    </nav>
    <article>
      <header class="mb-8">
        <div class="flex items-center gap-2 mb-3">
          <span class="px-3 py-1 bg-green-100 text-green-700 text-sm rounded-full">{category}</span>
          <span class="px-3 py-1 bg-amber-100 text-amber-700 text-sm rounded-full">{difficulty}</span>
          {duration && <span class="text-sm text-gray-500">⏱️ {duration}</span>}
        </div>
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">{title}</h1>
        <p class="text-lg text-gray-600 mb-4">{description}</p>
        <div class="flex items-center gap-4 text-sm text-gray-500">
          <span>作者：{author}</span>
          <time datetime={pubDate.toISOString()}>{pubDate.toLocaleDateString('zh-CN')}</time>
        </div>
      </header>
      <div class="prose prose-lg max-w-none">
        <Content />
      </div>
    </article>
    <div class="mt-12 pt-8 border-t flex justify-between items-center">
      <a href="/tutorial" class="text-primary hover:underline">← 返回教程列表</a>
      <a href="/product" class="text-primary hover:underline">浏览相关产品 →</a>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .prose { color: #374151; line-height: 1.8; }
  .prose h1, .prose h2, .prose h3 { color: #111827; font-weight: 700; margin-top: 2em; margin-bottom: 0.75em; }
  .prose h2 { font-size: 1.5rem; border-bottom: 1px solid #e5e7eb; padding-bottom: 0.5em; }
  .prose h3 { font-size: 1.25rem; }
  .prose p { margin-bottom: 1.25em; }
  .prose ul, .prose ol { margin-bottom: 1.25em; padding-left: 1.5em; }
  .prose li { margin-bottom: 0.5em; }
  .prose blockquote { border-left: 4px solid #C4956A; padding-left: 1em; color: #6b7280; font-style: italic; margin: 1.5em 0; }
  .prose strong { color: #111827; }
  .prose a { color: #C4956A; text-decoration: underline; }
</style>
